# ============================================================
# ClinicBoost — .env.staging.example
#
# Copia este archivo a .env.staging y rellena los valores reales.
# NUNCA commitas .env.staging al repositorio.
#
# USO:
#   cp .env.staging.example .env.staging
#   nano .env.staging   # o tu editor preferido
#   docker compose -f docker-compose.staging.yml --env-file .env.staging up -d
#
# VARIABLES REQUERIDAS (sin valor por defecto):
#   · DB_CONNECTION_STRING
#   · SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_JWT_SECRET
#   · TWILIO_ACCOUNT_SID / TWILIO_AUTH_TOKEN / TWILIO_WEBHOOK_BASE_URL
#   · VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY
#   · CORS_ORIGIN_0
#
# VARIABLES OPCIONALES (tienen valor por defecto seguro):
#   · OPENAI_API_KEY / ANTHROPIC_API_KEY  — solo si el agente conversacional está activo
#   · CSP_REPORT_ONLY                      — true en staging, false en producción
#   · CSP_REPORT_URI                       — endpoint para reportes CSP
# ============================================================

# ── Base de datos (Supabase Cloud) ─────────────────────────────────────────────
# Obtener en: Supabase Dashboard → Settings → Database → Connection string → .NET
# IMPORTANTE: usar el usuario "app_user" (no postgres) con permisos mínimos
# Formato: Host=db.<ref>.supabase.co;Port=5432;Database=postgres;Username=app_user;Password=XXXX;SSL Mode=Require;Trust Server Certificate=true
DB_CONNECTION_STRING=Host=db.XXXX.supabase.co;Port=5432;Database=postgres;Username=app_user;Password=CHANGE_ME;SSL Mode=Require;Trust Server Certificate=true

# ── Supabase (backend) ─────────────────────────────────────────────────────────
# Obtener en: Supabase Dashboard → Settings → API
SUPABASE_URL=https://XXXX.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.CHANGE_ME
SUPABASE_JWT_SECRET=CHANGE_ME_supabase_jwt_secret_min_32_chars

# ── Supabase (frontend — variables VITE_ baked en build-time) ─────────────────
# Estas variables se incrustan en el bundle de Vite durante la construcción Docker.
# Son las mismas URL/AnonKey que arriba pero con prefijo VITE_ para el frontend.
VITE_SUPABASE_URL=https://XXXX.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.CHANGE_ME
VITE_API_URL=https://staging.clinicboost.es

# ── CORS ───────────────────────────────────────────────────────────────────────
# Dominio(s) permitidos para peticiones cross-origin.
# CORS_ORIGIN_1 es opcional (por si hay varios dominios de staging).
CORS_ORIGIN_0=https://staging.clinicboost.es
CORS_ORIGIN_1=

# ── Twilio ─────────────────────────────────────────────────────────────────────
# Obtener en: https://console.twilio.com → Account Info
# TWILIO_WEBHOOK_BASE_URL debe apuntar al dominio público de staging
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WEBHOOK_BASE_URL=https://staging.clinicboost.es

# ── IA — Agente conversacional (opcionales) ────────────────────────────────────
# Dejar vacío si el agente conversacional no está activo en staging.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── CSP — Content Security Policy ─────────────────────────────────────────────
# En staging, mantener CSP_REPORT_ONLY=true para observar sin bloquear.
# Cambiar a false cuando las políticas sean estables.
CSP_REPORT_ONLY=true
CSP_REPORT_URI=/auth/csp-report
