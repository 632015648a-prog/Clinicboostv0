{
  "ConnectionStrings": {
    "Supabase": "CHANGE_ME_VIA_ENV_VAR"
  },
  "Supabase": {
    "Url": "CHANGE_ME_VIA_ENV_VAR",
    "AnonKey": "CHANGE_ME_VIA_ENV_VAR",
    "JwtSecret": "CHANGE_ME_VIA_ENV_VAR"
  },
  "Cors": {
    "AllowedOrigins": [
      "https://staging.clinicboost.es"
    ]
  },
  "Twilio": {
    "AccountSid": "CHANGE_ME_VIA_ENV_VAR",
    "AuthToken": "CHANGE_ME_VIA_ENV_VAR",
    "WebhookBaseUrl": "CHANGE_ME_VIA_ENV_VAR"
  },
  "Csp": {
    "ReportUri": "/auth/csp-report",
    "ReportOnly": true,
    "AdditionalConnectSrc": "https://*.supabase.co wss://*.supabase.co"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [T:{TenantId}] [U:{UserId}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "/app/logs/clinicboost-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] [T:{TenantId}] [U:{UserId}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  }
}
